{
    "framework": "create-react-app",
    "buildCommand": "GENERATE_SOURCEMAP=false npm run build",
    "outputDirectory": "build",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Referrer-Policy",
                    "value": "no-referrer"
                }
            ]
        }
    ]
}